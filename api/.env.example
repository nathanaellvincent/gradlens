# GradLens API — example environment config.
# Copy to .env and adjust for local overrides. .env is gitignored.

# Runtime environment: "dev" or "prod"
GRADLENS_ENV=dev

# Python logging level: DEBUG | INFO | WARNING | ERROR
GRADLENS_LOG_LEVEL=INFO

# Where LanceDB + SQLite live. Relative to cwd when the server runs.
GRADLENS_DATA_DIR=data

# Comma-separated list of allowed CORS origins for the Next.js frontend.
# JSON array form also works: ["http://localhost:3000"]
GRADLENS_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
