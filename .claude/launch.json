{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "gradlens-api",
      "runtimeExecutable": "uv",
      "runtimeArgs": [
        "run",
        "--directory",
        "api",
        "uvicorn",
        "gradlens_api.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000",
        "--reload"
      ],
      "port": 8000
    },
    {
      "name": "gradlens-web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--dir", "web", "dev", "--port", "3100"],
      "port": 3100
    }
  ]
}
